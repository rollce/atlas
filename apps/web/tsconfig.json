{
  "extends": "@atlas/config/tsconfig/react",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "next/link": ["src/shims/next-link.tsx"],
      "next/navigation": ["src/shims/next-navigation.ts"]
    },
    "noEmit": true,
    "incremental": true,
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules"]
}
