# Shared
NODE_ENV=development

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# API
PORT=4000
APP_VERSION=0.1.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atlas
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
ALTCHA_HMAC_KEY=replace_with_altcha_hmac_key

# Worker
WORKER_PORT=4040
WORKER_CONCURRENCY=10
WORKER_RETRY_ATTEMPTS=3
WORKER_RETRY_DELAY_MS=2000
IDEMPOTENCY_TTL_SECONDS=86400
